// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

//after changing anything here then we need to run this both -- 
//npx prisma migrate dev --name made_email_unique
//npx prisma generate

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}


model User {

  id          String    @id @default(uuid())
  //username       String 
  email       String    @unique 
  password    String
  name        String
  photo       String?

  //----------------below these are not will be there in table---------------
  //one user -- many rooms
  rooms       Room[]
  chats       Chat[]
}



model Room {
  id          Int       @id @default(autoincrement())
   // Unique room name...
  slud        String    @unique
  createdAt   DateTime  @default(now())
  // Foreign Key (stores User.id)...
  adminId     String



// Connected User object using adminId
  admin       User      @relation(fields: [adminId], references: [id] )
  chats       Chat[]
}


model Chat {
  //why id here is we are taking int?
  id          Int     @id @default(autoincrement())
  // Foreign Key -> stores Room.id
  roomId      Int
  message     String
  // Foreign Key -> stores User.id
  userId      String



  
  // Connected Room object using roomId
  room        Room      @relation(fields: [roomId], references: [id])
  // Connected User object using userId
  user        User      @relation(fields: [userId], references: [id])


}






/*

adminId -> stores id

admin -> gives one connected object

rooms -> gives many connected objects

*/


